# Hinglish Subtitle Creator — Environment Config
# Copy this to .env and fill in values

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Whisper model — options: tiny, base, small, medium, large-v2, large-v3
# large-v3 is best for Hinglish but needs ~6GB VRAM. Use medium on CPU.
WHISPER_MODEL=large-v3
WHISPER_DEVICE=auto          # auto | cpu | cuda
WHISPER_COMPUTE_TYPE=auto    # auto | int8 | float16 | float32

# File limits
MAX_UPLOAD_SIZE_MB=500
TEMP_FILE_TTL_HOURS=2        # auto-delete temp files after N hours

# Paths (relative to project root, or absolute)
TEMP_DIR=./temp

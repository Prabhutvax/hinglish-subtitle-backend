# ─────────────────────────────────────────────
# Hinglish Subtitle Creator — Production .env
# Copy to .env and fill in values
# ─────────────────────────────────────────────

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Whisper
# Use "medium" on CPU servers (Railway free tier)
# Use "large-v3" if you have a GPU instance
WHISPER_MODEL=medium
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# File limits
MAX_UPLOAD_SIZE_MB=200
TEMP_FILE_TTL_HOURS=2

# Paths
TEMP_DIR=./temp
